# JailHunter Environment Configuration
# Copy this file to .env and fill in your values.
# .env is never committed to git.

# ── OpenAI / compatible API ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1    # override for LM Studio, vLLM, etc.

# ── Ollama ────────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434        # default; change if Ollama runs elsewhere

# ── Request behaviour ─────────────────────────────────────────────────────────
# JH_TIMEOUT=60          # seconds per request
# JH_CONCURRENT=3        # max parallel requests
# JH_DELAY=0.5           # seconds between requests
# JH_RETRIES=3           # max retry attempts
# JH_RETRY_BASE=1.0      # retry base delay (doubles each attempt)

# ── Scoring ───────────────────────────────────────────────────────────────────
# JH_THRESHOLD=75        # score at which a result counts as a jailbreak

# ── Reports ───────────────────────────────────────────────────────────────────
# JH_REPORT_DIR=./jh_reports

# ── Debug ─────────────────────────────────────────────────────────────────────
# JH_DEBUG=false
# JH_VERBOSE=false
